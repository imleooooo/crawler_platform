RUSTFS_PUBLIC_ENDPOINT=""    # public-facing endpoint, e.g. https://storage.example.com
REDIS_URL=""                 # e.g. redis://redis:6379/0
ALLOWED_ORIGINS=""           # comma-separated; for local compose use http://localhost:5173
DATABASE_URL=""
POSTGRES_USER=""
POSTGRES_PASSWORD=""
POSTGRES_DB=""
